<VirtualHost *:80>
    ServerName sac.cas-nl.com
    Redirect permanent / https://sac.cas-nl.com/
</VirtualHost>

# Vereist: sudo a2enmod headers rewrite proxy proxy_http ssl
<VirtualHost *:443>
    ServerName sac.cas-nl.com
    DocumentRoot /var/www/html/sac

    <Directory /var/www/html/sac>
        Options -Indexes +FollowSymLinks
        AllowOverride All
        Require all granted
        # SPA: nooit index.html of service worker lang cachen — anders blijft oude bundle actief
        <FilesMatch "^(index\.html|sw\.js|manifest\.json)$">
            Header set Cache-Control "no-cache, no-store, must-revalidate"
        </FilesMatch>
        RewriteEngine On
        RewriteBase /
        RewriteRule ^index\.html$ - [L]
        RewriteCond %{REQUEST_FILENAME} !-f
        RewriteCond %{REQUEST_FILENAME} !-d
        RewriteRule . /index.html [L]
    </Directory>

    ProxyPreserveHost On
    ProxyPass /api/ http://127.0.0.1:3001/api/
    ProxyPassReverse /api/ http://127.0.0.1:3001/api/

    SSLCertificateFile /etc/letsencrypt/live/sac.cas-nl.com/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/sac.cas-nl.com/privkey.pem
    Include /etc/letsencrypt/options-ssl-apache.conf

    ErrorLog ${APACHE_LOG_DIR}/cas-error.log
    CustomLog ${APACHE_LOG_DIR}/cas-access.log combined
</VirtualHost>
