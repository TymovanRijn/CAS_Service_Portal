PORT=3001
NODE_ENV=production
HOST=0.0.0.0

JWT_SECRET=replace_with_a_long_random_secret

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cas_service_portal
DB_USER=postgres
DB_PASSWORD=replace_with_db_password

CORS_ORIGIN=https://sac.cas-nl.com,https://www.sac.cas-nl.com,http://sac.cas-nl.com,http://www.sac.cas-nl.com

# Optional: system Chrome/Chromium if Puppeteer's bundled browser fails (dagrapport-PDF on Linux servers)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# CHROME_PATH=/usr/bin/google-chrome-stable

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_REASONING=off
